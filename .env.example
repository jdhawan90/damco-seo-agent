# ============================================================================
# Damco SEO AI Agent System — environment configuration
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# ============================================================================

# ---- Database ---------------------------------------------------------------
# Local PostgreSQL. Change host/port when deploying to cloud.
DATABASE_URL=postgresql://damco_seo:CHANGE_ME@localhost:5432/damco_seo
# Optional pool sizing (defaults: min 1, max 5).
DB_POOL_MIN=1
DB_POOL_MAX=5

# ---- DataForSEO -------------------------------------------------------------
# https://app.dataforseo.com/api-access
DATAFORSEO_LOGIN=your_login_here
DATAFORSEO_PASSWORD=your_password_here
# Default queue: "standard" (cheap, async ~1-5 min) or "live" (expensive, sync).
DATAFORSEO_DEFAULT_QUEUE=standard
# Default SERP location and language.
DATAFORSEO_LOCATION_CODE=2840
DATAFORSEO_LANGUAGE_CODE=en
DATAFORSEO_DEVICE=desktop

# ---- Google Search Console (OAuth 2.0) --------------------------------------
# OAuth client created in Google Cloud Console. Token file is generated on first run.
GSC_CLIENT_SECRETS_FILE=./secrets/gsc_client_secrets.json
GSC_TOKEN_FILE=./secrets/gsc_token.json
GSC_SITE_URL=https://www.damcogroup.com/

# ---- PageSpeed Insights -----------------------------------------------------
# https://developers.google.com/speed/docs/insights/v5/get-started
PAGESPEED_API_KEY=your_key_here

# ---- Anthropic (Claude API) -------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...
# Default model tier: haiku for cheap routine tasks, sonnet for most, opus for complex.
CLAUDE_MODEL_CHEAP=claude-haiku-4-5-20251001
CLAUDE_MODEL_DEFAULT=claude-sonnet-4-6
CLAUDE_MODEL_COMPLEX=claude-opus-4-6

# ---- Notifications (optional, for agents that alert) ------------------------
SLACK_WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=seo-agents@damcogroup.com

# ---- Runtime ----------------------------------------------------------------
# Logging: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
# Base directory for generated outputs (PDFs, reports, drafts). Relative to repo root.
OUTPUTS_DIR=./outputs
